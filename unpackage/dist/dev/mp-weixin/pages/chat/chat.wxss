
.chat-container.data-v-0a633310 {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f7f9fc;
}

/* 顶部导航栏 */
.top-nav.data-v-0a633310 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 16px;
  background-color: #f7f9fc;
  border-bottom: 1px solid #e0e3e6;
}
.nav-left.data-v-0a633310 {
  display: flex;
  align-items: center;
}
.back-btn.data-v-0a633310 {
  font-size: 20px;
  color: #3F8EF7;
  margin-right: 12px;
}
.chat-user-info.data-v-0a633310 {
  display: flex;
  flex-direction: column;
}
.chat-name.data-v-0a633310 {
  font-size: 16px;
  font-weight: bold;
  color: #191c1e;
}
.online-status.data-v-0a633310 {
  display: flex;
  align-items: center;
  margin-top: 2px;
}
.status-dot.data-v-0a633310 {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background-color: #006c52;
  margin-right: 4px;
  box-shadow: 0 0 4px #006c52;
}
.status-text.data-v-0a633310 {
  font-size: 10px;
  color: #006c52;
}
.online-status.offline .status-text.data-v-0a633310 {
  color: #999;
}
.more-btn.data-v-0a633310 {
  font-size: 20px;
  color: #3F8EF7;
}

/* 聊天内容区域 */
.chat-content.data-v-0a633310 {
  flex: 1;
  padding: 20px 0px;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
}
.message-item.data-v-0a633310 {
  display: flex;
  margin-bottom: 20px;
  align-items: flex-start;
  max-width: 100%;
}
.avatar-container.data-v-0a633310 {
  width: 64px;
  height: 40px;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  flex-shrink: 0;
}

/* 自己消息的头像容器 - 右侧间距 */
.message-item.my-message .avatar-container.data-v-0a633310 {
  padding-right: 8px;
}

/* 对方消息的头像容器 - 左侧间距 */
.message-item:not(.my-message) .avatar-container.data-v-0a633310 {
  padding-left: 8px;
}
.message-item.my-message.data-v-0a633310 {
  flex-direction: row;
}
.message-item.my-message .message-content.data-v-0a633310 {
  align-items: flex-end;
}
.message-item:not(.my-message) .message-content.data-v-0a633310 {
  align-items: flex-start;
}
.avatar.data-v-0a633310 {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  flex-shrink: 0;
}
.message-content.data-v-0a633310 {
  flex: 1;
  max-width: 85%;
  display: flex;
  flex-direction: column;
}
.message-bubble.data-v-0a633310 {
  max-width: 100%;
  padding: 12px 16px;
  border-radius: 16px;
  position: relative;
  display: inline-block;
}
.message-bubble.data-v-0a633310:not(.my-bubble) {
  background-color: #f2f4f7;
  border-bottom-left-radius: 4px;
}
.message-bubble.my-bubble.data-v-0a633310 {
  background-color: #1173db;
  color: white;
  border-bottom-right-radius: 4px;
}
.message-bubble.data-v-0a633310:not(.my-bubble)::before {
  content: '';
  position: absolute;
  left: -8px;
  top: 14px;
  border-width: 4px 8px 4px 0;
  border-style: solid;
  border-color: transparent #f2f4f7 transparent transparent;
}
.message-bubble.my-bubble.data-v-0a633310::before {
  content: '';
  position: absolute;
  right: -8px;
  top: 14px;
  border-width: 4px 0 4px 8px;
  border-style: solid;
  border-color: transparent transparent transparent #1173db;
}
.message-text.data-v-0a633310 {
  font-size: 14px;
  line-height: 1.4;
}
.message-time.data-v-0a633310 {
  font-size: 10px;
  opacity: 0.7;
  margin-top: 4px;
  display: block;
}
.message-bubble.my-bubble .message-time.data-v-0a633310 {
  color: rgba(255, 255, 255, 0.7);
  text-align: right;
}

/* 输入区域 */
.input-area.data-v-0a633310 {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  background-color: #ffffff;
  border-top: 1px solid #f0f0f0;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
}
.input.data-v-0a633310 {
  flex: 1;
  padding: 10px 16px;
  background-color: #f0f0f0;
  border-radius: 20px;
  border: none;
  outline: none;
  font-size: 14px;
  margin-right: 12px;
}
.send-btn.data-v-0a633310 {
  color: #3F8EF7;
  font-size: 14px;
  font-weight: bold;
  white-space: nowrap;
}
